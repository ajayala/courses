{
  "version": 1,
  "steps": [
    {
      "stepIndex": 0,
      "checks": [
        {
          "type": "command_output_matches",
          "description": "feature/add-health-check branch exists",
          "command": "git -C vscode-prod-app branch",
          "pattern": "feature/add-health-check"
        }
      ]
    },
    {
      "stepIndex": 1,
      "checks": [
        {
          "type": "file_exists",
          "description": "src/health.py was created",
          "path": "vscode-prod-app/src/health.py"
        },
        {
          "type": "file_contains",
          "description": "health.py defines a check function",
          "path": "vscode-prod-app/src/health.py",
          "contains": "def check"
        }
      ]
    },
    {
      "stepIndex": 3,
      "checks": [
        {
          "type": "command_output_matches",
          "description": "Branch has at least one commit for the health check",
          "command": "git -C vscode-prod-app log --oneline feature/add-health-check",
          "pattern": "health"
        }
      ]
    },
    {
      "stepIndex": 5,
      "checks": [
        {
          "type": "command_output_matches",
          "description": "No WIP or debug commit remains in branch history",
          "command": "git -C vscode-prod-app log --oneline feature/add-health-check",
          "pattern": "^(?!.*[Ww][Ii][Pp])(?!.*debug).*"
        },
        {
          "type": "command_exits_zero",
          "description": "health.py does not contain the debug flag",
          "command": "grep -L 'debug' vscode-prod-app/src/health.py"
        }
      ]
    }
  ]
}
