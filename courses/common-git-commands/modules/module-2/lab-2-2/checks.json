{
  "version": 1,
  "steps": [
    {
      "stepIndex": 0,
      "checks": [
        {
          "type": "command_exits_zero",
          "description": "Working tree is clean after git restore",
          "command": "git diff --quiet && git diff --cached --quiet"
        }
      ]
    },
    {
      "stepIndex": 2,
      "checks": [
        {
          "type": "command_output_matches",
          "description": "Most recent commit message does not contain typo",
          "command": "git log -1 --pretty=%s",
          "pattern": "^(?!.*tyop).*"
        }
      ]
    },
    {
      "stepIndex": 3,
      "checks": [
        {
          "type": "command_output_matches",
          "description": "History contains a revert commit",
          "command": "git log --oneline",
          "pattern": "[Rr]evert"
        }
      ]
    },
    {
      "stepIndex": 5,
      "checks": [
        {
          "type": "command_exits_zero",
          "description": "git reflog returns output (reflog is populated)",
          "command": "git reflog | head -1"
        }
      ]
    }
  ]
}
