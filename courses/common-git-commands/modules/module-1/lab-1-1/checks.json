{
  "version": 1,
  "steps": [
    {
      "stepIndex": 0,
      "checks": [
        {
          "type": "command_output_matches",
          "description": "git config has user.name set",
          "command": "git config --global user.name",
          "pattern": ".+"
        },
        {
          "type": "command_output_matches",
          "description": "git config has user.email set",
          "command": "git config --global user.email",
          "pattern": ".+@.+"
        }
      ]
    },
    {
      "stepIndex": 1,
      "checks": [
        {
          "type": "file_exists",
          "description": ".git directory exists inside my-git-project",
          "path": "my-git-project/.git"
        }
      ]
    },
    {
      "stepIndex": 3,
      "checks": [
        {
          "type": "file_exists",
          "description": "README.md exists in the project",
          "path": "my-git-project/README.md"
        },
        {
          "type": "file_contains",
          "description": "README.md contains the project heading",
          "path": "my-git-project/README.md",
          "contains": "My Git Project"
        }
      ]
    },
    {
      "stepIndex": 5,
      "checks": [
        {
          "type": "command_exits_zero",
          "description": "Repository has at least one commit",
          "command": "git -C my-git-project log --oneline"
        },
        {
          "type": "command_output_matches",
          "description": "First commit message mentions README",
          "command": "git -C my-git-project log --oneline",
          "pattern": "README"
        }
      ]
    }
  ]
}
